# =============================================================================
# Production / Preview env template (Vercel)
# =============================================================================

# -- Supabase (required) -------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# -- App (required) ------------------------------------------------------------
# Local: http://localhost:3000
# Production: https://<your-domain-or-vercel-domain>
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=<64-char-hex>
# Optional upload-size hint (MB) used by /projects/new client-side validation.
# Keep this aligned with Supabase Storage bucket file_size_limit.
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=500

# -- Dev-only (optional) -------------------------------------------------------
# Comma-separated hostnames or URLs for dev cross-origin asset requests.
# Example: ALLOWED_DEV_ORIGINS=192.168.0.103,http://10.0.0.8:3000
ALLOWED_DEV_ORIGINS=
# 1 force-enable dev direct register; 0 force-disable; empty = auto local/private host detection
DEV_AUTH_BYPASS=

# -- AI providers (at least one required) --------------------------------------
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
STABILITY_API_KEY=
KLING_API_KEY=
RUNWAY_API_KEY=

# -- Storage / Supabase (required for media pipeline) --------------------------
# Defaults to "videos" if omitted. Keep this aligned with Supabase migrations.
SUPABASE_STORAGE_BUCKET=videos
# Optional client-side override for upload page.
# Set only when you use a custom bucket name, and keep it equal to SUPABASE_STORAGE_BUCKET.
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=

# -- Inngest (required) --------------------------------------------------------
# Vercel: Inngest Cloud app URL -> https://<deployment>/api/inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# -- Redis / Queue (optional but recommended) ----------------------------------
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -- Langfuse (optional) -------------------------------------------------------
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# -- Quotas (optional, with defaults) ------------------------------------------
QUOTA_MAX_PROJECTS_PER_DAY=5
QUOTA_MAX_PROJECTS_TOTAL=50
QUOTA_MAX_COST_PER_PROJECT=10
QUOTA_MAX_COST_PER_DAY=20
QUOTA_MAX_COST_PER_MONTH=100

# -- E2E / release checks (optional, only for CI) ------------------------------
E2E_OWNER_EMAIL=
E2E_OWNER_PASSWORD=
E2E_NON_OWNER_EMAIL=
E2E_NON_OWNER_PASSWORD=
LIVE_REFERENCE_VIDEO_URL=
REQUIRE_LIVE_ACCEPTANCE=
PLAYWRIGHT_BASE_URL=
PLAYWRIGHT_LIVE=
E2E_BYPASS_AUTH=
E2E_BYPASS_GUARD=
